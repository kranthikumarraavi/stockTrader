docker-compose.override.yml

# Ignore everything by default
/*

# Allow only frontend directory and its contents
!frontend/
!frontend/**

# Ignore frontend/node_modules and build outputs
frontend/node_modules/
frontend/dist/
frontend/.angular/

# Ignore OS/IDE files in frontend
frontend/.DS_Store
frontend/Thumbs.db
frontend/.vscode/
frontend/.idea/

# Downloaded data
storage/raw/*.csv
storage/backtests/*/
storage/runtime/
storage/angel_tokens.json

# Node modules
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.angular/
frontend/coverage/

# Logs
logs/*.log

# Feature store manifest (auto-generated)
backend/prediction_engine/feature_store/manifest.json


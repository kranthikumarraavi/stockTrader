# ═══════════════════════════════════════════════════════════════════════
#  StockTrader – Environment Variables
# ═══════════════════════════════════════════════════════════════════════
#  Copy this file to .env and fill in your values.
#  All services read from the same .env file.
# ═══════════════════════════════════════════════════════════════════════

# ── General ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# ── Database ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://stocktrader:stocktrader@localhost:5432/stocktrader
POSTGRES_USER=stocktrader
POSTGRES_PASSWORD=stocktrader

# ── Redis ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── RabbitMQ ────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ── Data Paths ──────────────────────────────────────────────────────
MODEL_REGISTRY_PATH=models/registry.json
MARKET_DATA_PATH=storage/raw
STORAGE_PATH=storage

# ── Service Ports (for local development) ───────────────────────────
# These are the default ports. Override only if needed.
# GATEWAY_PORT=8000
# MARKET_DATA_PORT=8001
# PREDICTION_PORT=8002
# TRADING_PORT=8003
# PORTFOLIO_RISK_PORT=8004
# BACKTEST_PORT=8005
# MODEL_MANAGEMENT_PORT=8006
# EXECUTION_PORT=8007
# OPTIONS_SIGNAL_PORT=8008
# INTRADAY_FEATURE_PORT=8009
# INTRADAY_PREDICTION_PORT=8010
# TRADE_SUPERVISOR_PORT=8011

# ── Service URLs (for inter-service communication) ──────────────────
# In Docker, these resolve to container names (set in docker-compose).
# For local dev, these default to localhost:<port>.
MARKET_DATA_URL=http://localhost:8001
PREDICTION_URL=http://localhost:8002
TRADING_URL=http://localhost:8003
PORTFOLIO_RISK_URL=http://localhost:8004
BACKTEST_URL=http://localhost:8005
MODEL_MANAGEMENT_URL=http://localhost:8006
EXECUTION_URL=http://localhost:8007
OPTIONS_SIGNAL_URL=http://localhost:8008
INTRADAY_FEATURE_URL=http://localhost:8009
INTRADAY_PREDICTION_URL=http://localhost:8010
TRADE_SUPERVISOR_URL=http://localhost:8011

# ── Gateway Timeouts ───────────────────────────────────────────────
GATEWAY_UPSTREAM_TIMEOUT_S=60
GATEWAY_RETRAIN_TIMEOUT_S=900
GATEWAY_BACKTEST_TIMEOUT_S=600

# ── Market Data Service ────────────────────────────────────────────
MDS_SCHEDULER_ENABLED=true
MDS_SCHEDULER_REFRESH_MINUTES=240
MARKET_DATA_BOOTSTRAP_DOWNLOAD=false
# MDS_DEFAULT_SYMBOLS=RELIANCE,TCS,INFY,HDFCBANK

# ── Prediction ─────────────────────────────────────────────────────
PREDICTION_NO_TRADE_BAND_SCALE=0.25

# ── Angel One Broker (required for live trading) ───────────────────
# ANGEL_API_KEY=
# ANGEL_CLIENT_ID=
# ANGEL_MPIN=
# ANGEL_TOTP_SECRET=

# ── Monitoring ─────────────────────────────────────────────────────
# SENTRY_DSN=
PROMETHEUS_ENABLED=true

# ── Grafana ────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

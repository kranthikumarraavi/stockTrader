{
  "framework": "angular",
  "buildCommand": "npx ng build --configuration production",
  "outputDirectory": "dist/stocktrader-frontend/browser",
  "installCommand": "npm ci",
  "rewrites": [
    {
      "source": "/api/prediction/:path*",
      "destination": "https://stocktrader-prediction-irpt.onrender.com/api/:path*"
    },
    {
      "source": "/api/admin/:path*",
      "destination": "https://stocktrader-admin-irpt.onrender.com/api/:path*"
    },
    {
      "source": "/api/trading/:path*",
      "destination": "https://stocktrader-trading-irpt.onrender.com/api/:path*"
    },
    {
      "source": "/api/market-data/:path*",
      "destination": "https://stocktrader-market-data-irpt.onrender.com/api/:path*"
    },
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
